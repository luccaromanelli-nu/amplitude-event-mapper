# Business unit — drives Mantiqueira group + Databricks workspace.
NU_BU=cc-financing

# Country — BR | MX | CO. Drives table names, naming patterns, defaults.
NU_COUNTRY=MX

# Databricks read-only access (Magnitude / Amplitude exports).
NU_DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
NU_DATABRICKS_TOKEN=
NU_DATABRICKS_WAREHOUSE_ID=
NU_DATABRICKS_WORKSPACE=credit-strategy

# Figma personal access token (read-only).
FIGMA_TOKEN=

# Default property values applied to proposals when caller does not override.
NU_DEFAULT_PROVIDER=finn
NU_DEFAULT_PACKAGE=catalyst_entrypoint

# Path to the seed catalog of canonical events.
NU_CATALOG_PATH=catalog/events.md
